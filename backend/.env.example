# Copy to backend/.env and fill in real values.
# NEVER commit the real .env file — it's already in backend/.gitignore.

# --- Core ---------------------------------------------------------
NODE_ENV=production
PORT=5000

# --- Database -------------------------------------------------------
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority

# --- Auth -------------------------------------------------------------
JWT_SECRET=replace-with-a-long-random-value-min-32-bytes

# --- CORS ---------------------------------------------------------------
# Exact origin of the deployed frontend (scheme + host, no trailing slash)
ALLOWED_ORIGIN=https://your-portfolio-domain.com

# --- Cloudinary -----------------------------------------------------------
CLOUD_NAME=your-cloud-name
CLOUD_API_KEY=your-api-key
CLOUD_API_SECRET=your-api-secret

# --- Logging (optional, defaults shown) ------------------------------------
LOG_LEVEL=info
